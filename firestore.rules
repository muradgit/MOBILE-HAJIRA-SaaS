rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: tenants
    // Fields: tenant_id, name, eiin, institutionType, credits_left, status, admin_name, admin_mobile, owner_email, googleSheetId, created_at
    //
    // Collection: users
    // Fields: user_id, tenant_id, role, name, email, phone, status, student_id, teacher_id, class, section
    //
    // Collection: session_codes
    // Fields: code, tenant_id, teacher_id, subject, expires_at
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      let userData = getUserData();
      return isAuthenticated() && (
        (request.auth.token.email == "hello@muradkhank31.com" && request.auth.token.email_verified == true) ||
        (userData != null && userData.role == "SuperAdmin")
      );
    }

    function getUserData() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data : null;
    }

    function isInstitutionAdmin(tenantId) {
      let userData = getUserData();
      return isAuthenticated() && userData != null && userData.tenant_id == tenantId && userData.role == "InstitutionAdmin";
    }

    function isTeacher(tenantId) {
      let userData = getUserData();
      return isAuthenticated() && userData != null && userData.tenant_id == tenantId && userData.role == "Teacher";
    }

    function belongsToTenant(tenantId) {
      let userData = getUserData();
      return isAuthenticated() && userData != null && userData.tenant_id == tenantId;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Tenants
    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || belongsToTenant(tenantId);
      allow create: if isAuthenticated();
      allow delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || (isInstitutionAdmin(tenantId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'admin_name', 'admin_mobile']));
    }

    // Users
    match /users/{userId} {
      allow read: if isSuperAdmin() || request.auth.uid == userId;
      allow create: if isSuperAdmin() || (request.auth.uid == userId && request.resource.data.role != "SuperAdmin");
      allow update: if isSuperAdmin() || (request.auth.uid == userId && request.resource.data.role == resource.data.role);
      allow delete: if isSuperAdmin();
    }

    // Session Codes
    match /session_codes/{codeId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin() || isTeacher(request.resource.data.tenant_id);
      allow delete: if isSuperAdmin() || isTeacher(resource.data.tenant_id);
    }
  }
}
