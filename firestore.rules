rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "hello@muradkhank31.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "SuperAdmin"
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function belongsToTenant(tenantId) {
      return isAuthenticated() && getUserData().tenant_id == tenantId;
    }

    function isInstitutionAdmin(tenantId) {
      let data = getUserData();
      return isAuthenticated() && data.tenant_id == tenantId && (data.role == "InstitutionAdmin" || data.role == "Admin");
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Tenants
    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || belongsToTenant(tenantId);
      allow create: if isAuthenticated();
      allow update: if isSuperAdmin() || isInstitutionAdmin(tenantId);
      allow delete: if isSuperAdmin();

      // Subcollections
      match /teachers/{teacherId} {
        allow read: if isSuperAdmin() || belongsToTenant(tenantId);
        allow write: if isSuperAdmin() || isInstitutionAdmin(tenantId) || request.auth.uid == teacherId;
      }

      match /students/{studentId} {
        allow read: if isSuperAdmin() || belongsToTenant(tenantId);
        allow write: if isSuperAdmin() || isInstitutionAdmin(tenantId) || request.auth.uid == studentId;
      }
    }

    // Users
    match /users/{userId} {
      allow read: if isSuperAdmin() || request.auth.uid == userId || (isAuthenticated() && getUserData().tenant_id == resource.data.tenant_id);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isSuperAdmin() || request.auth.uid == userId || isInstitutionAdmin(resource.data.tenant_id);
      allow delete: if isSuperAdmin();
    }

    // Misc Collections
    match /sms_history/{id} {
      allow read, write: if isAuthenticated() && (isSuperAdmin() || isInstitutionAdmin(getUserData().tenant_id));
    }

    match /session_codes/{id} {
      allow read, write: if isAuthenticated();
    }

    match /system_logs/{id} {
      allow read, write: if isSuperAdmin();
    }

    // --- Super Admin - Dashboard Modules ---

    // 1. System Settings
    match /system_settings/{docId} {
      allow read: if true; 
      allow write: if isSuperAdmin();
    }

    // 2. Payments
    match /payments/{paymentId} {
      allow read, write: if isAuthenticated(); // Admins create, SuperAdmin manages
    }

    // 3. Promo Codes
    match /promo_codes/{codeId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // 4. Broadcasts
    match /broadcasts/{broadcastId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // 5. Transactions
    match /transactions/{transactionId} {
      allow read: if isSuperAdmin();
      allow write: if isAuthenticated();
    }
  }
}
