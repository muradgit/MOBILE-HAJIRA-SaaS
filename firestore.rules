rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Phase 3: Primitive Definitions (Hardened Helpers)
    // ===============================================================
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() in ["hello@muradkhank31.com", "muradkhan31@gmail.com"] ||
        request.auth.token.role == "super_admin"
      );
    }

    function getTenantId() {
      return request.auth.token.tenant_id;
    }

    function getRole() {
      return request.auth.token.role;
    }

    function isMemberOfTenant(tenantId) {
      return isSignedIn() && (isSuperAdmin() || getTenantId() == tenantId);
    }

    function isInstitutionAdmin(tenantId) {
      return isSuperAdmin() || (isMemberOfTenant(tenantId) && getRole() == "institute_admin");
    }

    // ===============================================================
    // Global Safety Net & Super Admin Override
    // ===============================================================
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // ===============================================================
    // Entity Validations
    // ===============================================================
    
    function isValidTenant(data) {
      return data.keys().hasAll(['tenant_id', 'name', 'owner_email', 'status']) &&
             data.tenant_id is string && data.tenant_id.size() <= 100 &&
             data.name is string && data.name.size() <= 200 &&
             data.owner_email is string && data.owner_email.size() <= 100 &&
             data.status in ['active', 'suspended', 'pending'];
    }

    function isValidUser(data) {
      return data.keys().hasAll(['user_id', 'email', 'role', 'status']) &&
             data.user_id is string && data.user_id.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['super_admin', 'institute_admin', 'teacher', 'student'] &&
             data.status in ['approved', 'pending', 'blocked'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || isMemberOfTenant(tenantId);
      allow create: if isSuperAdmin() || (isSignedIn() && isValidTenant(incoming()) && incoming().tenant_id == tenantId);
      allow update: if isSuperAdmin() || (isInstitutionAdmin(tenantId) && isValidTenant(incoming()) && incoming().tenant_id == tenantId);
      allow delete: if isSuperAdmin();

      match /teachers/{teacherId} {
        allow read: if isSuperAdmin() || isMemberOfTenant(tenantId);
        allow create, update: if isSuperAdmin() || isInstitutionAdmin(tenantId);
        allow delete: if isSuperAdmin();
      }

      match /students/{studentId} {
        allow read: if isSuperAdmin() || isMemberOfTenant(tenantId);
        allow create, update: if isSuperAdmin() || isInstitutionAdmin(tenantId) || (isMemberOfTenant(tenantId) && getRole() == "teacher");
        allow delete: if isSuperAdmin();
      }
    }

    match /users/{userId} {
      allow read: if isSuperAdmin() || request.auth.uid == userId || (isSignedIn() && getTenantId() == resource.data.tenant_id);
      allow create: if isSuperAdmin() || (isSignedIn() && request.auth.uid == userId && isValidUser(incoming()));
      allow update: if isSuperAdmin() || (request.auth.uid == userId && isValidUser(incoming()));
      allow delete: if isSuperAdmin();
    }

    match /broadcasts/{broadcastId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /payments/{paymentId} {
       allow read: if isSuperAdmin() || (isSignedIn() && (incoming().tenant_id == request.auth.token.tenant_id || existing().tenant_id == request.auth.token.tenant_id));
       allow write: if isSignedIn(); // Add more strict validation here if needed
    }
  }
}
