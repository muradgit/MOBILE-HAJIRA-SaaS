rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // GLOBAL HELPERS
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.role == "super_admin" ||
        request.auth.token.email.lower() in ["hello@muradkhank31.com", "muradkhan31@gmail.com"]
      );
    }

    function getTenantId() {
      return request.auth.token.tenant_id;
    }

    function getRole() {
      return request.auth.token.role;
    }

    function isMemberOfTenant(tenantId) {
      return isSignedIn() && (isSuperAdmin() || getTenantId() == tenantId);
    }

    function isInstitutionAdmin(tenantId) {
      return isSuperAdmin() || (isMemberOfTenant(tenantId) && getRole() == "institute_admin");
    }

    function isTeacher(tenantId) {
      return isMemberOfTenant(tenantId) && getRole() == "teacher";
    }

    // ===============================================================
    // SECURITY OVERRIDE (Super Admin)
    // ===============================================================
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // ===============================================================
    // SCHEMA VALIDATION (Lean & Robust)
    // ===============================================================
    
    function isValidUserSchema(data) {
      return data.keys().hasAll(['user_id', 'email', 'role']) &&
             data.user_id is string &&
             data.email is string &&
             data.role is string;
    }

    function isValidNotificationSchema(data) {
      return data.keys().hasAll(['user_id', 'title', 'body', 'createdAt']) &&
             data.user_id is string &&
             data.title is string &&
             data.body is string &&
             data.createdAt is timestamp;
    }

    function isValidTenantSchema(data) {
      return data.keys().hasAll(['tenant_id', 'name']) &&
             data.tenant_id is string &&
             data.name is string;
    }

    function isValidTeacherClassSchema(data) {
      return data.keys().hasAll(['teacher_id', 'name']) &&
             data.teacher_id is string &&
             data.name is string &&
             data.name.size() <= 128;
    }

    // ===============================================================
    // COLLECTION RULES
    // ===============================================================

    // Tenants
    match /tenants/{tenantId} {
      allow read: if isMemberOfTenant(tenantId);
      allow create: if isSuperAdmin() || (isSignedIn() && isValidTenantSchema(request.resource.data));
      allow update: if isSuperAdmin() || (isInstitutionAdmin(tenantId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'nameBN', 'eiin', 'googleSheetId', 'academicLevels', 'recharge_status', 'last_active_date', 'website', 'phone', 'address', 'admin_name', 'admin_mobile', 'classes', 'departments', 'sessions', 'shifts', 'institutionType', 'updatedAt']));
      allow delete: if isSuperAdmin();

      // Subcollections
      match /admins/{id} { allow read, write: if isInstitutionAdmin(tenantId); }
      match /teachers/{id} { allow read, write: if isInstitutionAdmin(tenantId); }
      match /students/{id} { 
        allow read: if isMemberOfTenant(tenantId);
        allow write: if isInstitutionAdmin(tenantId) || isTeacher(tenantId);
      }
      
      match /teacher_classes/{classId} {
        allow read: if isMemberOfTenant(tenantId) && (isInstitutionAdmin(tenantId) || resource.data.teacher_id == request.auth.uid);
        allow create: if isMemberOfTenant(tenantId) && (isInstitutionAdmin(tenantId) || isTeacher(tenantId)) && isValidTeacherClassSchema(request.resource.data);
        allow update: if isMemberOfTenant(tenantId) && (isInstitutionAdmin(tenantId) || (resource.data.teacher_id == request.auth.uid && isValidTeacherClassSchema(request.resource.data)));
        allow delete: if isMemberOfTenant(tenantId) && (isInstitutionAdmin(tenantId) || resource.data.teacher_id == request.auth.uid);
      }
      
      // Attendance & Data
      match /attendance_logs/{id} { allow read, write: if isMemberOfTenant(tenantId); }
      match /attendance_sessions/{id} { allow read, write: if isMemberOfTenant(tenantId); }
      match /attendance_entries/{id} { 
        allow read: if isMemberOfTenant(tenantId);
        allow create: if isMemberOfTenant(tenantId);
        allow update, delete: if isTeacher(tenantId) || isInstitutionAdmin(tenantId);
      }
      match /settings/{id} { allow read, write: if isInstitutionAdmin(tenantId); }
      match /credit_history/{id} { 
        allow read: if isInstitutionAdmin(tenantId);
        allow write: if false; // Only via API
      }
    }

    // Macrodroid Payments
    match /macrodroid_payments/{id} {
      allow read, write: if isSuperAdmin();
    }

    // Global User Profiles
    match /users/{userId} {
      allow read: if isSuperAdmin() || request.auth.uid == userId || (isSignedIn() && getTenantId() == resource.data.tenant_id);
      allow create: if isSuperAdmin() || (isSignedIn() && request.auth.uid == userId && isValidUserSchema(request.resource.data));
      allow update: if isSuperAdmin() || (request.auth.uid == userId) || (isSignedIn() && isInstitutionAdmin(resource.data.tenant_id));
      allow delete: if isSuperAdmin();
    }

    // Notifications
    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSuperAdmin(); // Usually created via API/Server
      allow update: if isSignedIn() && resource.data.user_id == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    // System Config
    match /broadcasts/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /sms_history/{id} {
      allow read: if isSuperAdmin() || isInstitutionAdmin(getTenantId());
      allow write: if isSuperAdmin();
    }

    match /payments/{id} {
      allow read: if isSuperAdmin() || (isSignedIn() && (resource.data.tenant_id == getTenantId() || request.resource.data.tenant_id == getTenantId()));
      allow write: if isSignedIn();
    }
    
    match /session_codes/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
