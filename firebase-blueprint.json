{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Information about an educational institution",
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "name": { "type": "string" },
        "nameBN": { "type": "string" },
        "eiin": { "type": "string" },
        "googleSheetId": { "type": "string" },
        "owner_email": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended", "pending"] },
        "credits_left": { "type": "number" },
        "academicLevels": { "type": "array" }
      },
      "required": ["tenant_id", "name", "owner_email"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "institute_admin", "teacher", "student"] },
        "tenant_id": { "type": "string" },
        "status": { "type": "string", "enum": ["approved", "pending", "blocked"] }
      },
      "required": ["user_id", "email", "role"]
    }
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Collection of all tenants (institutes)"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Global collection of all users"
    },
    "/tenants/{tenantId}/teachers/{teacherId}": {
      "schema": "User",
      "description": "Subcollection for teacher quick lookup"
    },
    "/tenants/{tenantId}/students/{studentId}": {
      "schema": "User",
      "description": "Subcollection for student quick lookup"
    }
  }
}
