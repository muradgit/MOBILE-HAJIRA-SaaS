{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "An educational institution (school/college).",
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "name": { "type": "string" },
        "eiin": { "type": "string" },
        "website": { "type": "string" },
        "phone": { "type": "string" },
        "credits_left": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "promo_code": { "type": "string" },
        "referral_count": { "type": "number" }
      },
      "required": ["tenant_id", "name", "eiin", "credits_left", "status"]
    },
    "User": {
      "title": "User",
      "description": "A user belonging to a tenant (SuperAdmin, SchoolAdmin, Teacher).",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "tenant_id": { "type": "string" },
        "role": { "type": "string", "enum": ["SuperAdmin", "SchoolAdmin", "Teacher"] },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "password_hash": { "type": "string" }
      },
      "required": ["user_id", "tenant_id", "role", "name"]
    },
    "Student": {
      "title": "Student",
      "description": "A student enrolled in an institution.",
      "type": "object",
      "properties": {
        "student_id": { "type": "string" },
        "tenant_id": { "type": "string" },
        "level": { "type": "string" },
        "dept": { "type": "string" },
        "session": { "type": "string" },
        "roll": { "type": "string" },
        "unique_id": { "type": "string" },
        "qr_image_url": { "type": "string" }
      },
      "required": ["student_id", "tenant_id", "level", "dept", "session", "roll", "unique_id"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "An attendance record.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "tenant_id": { "type": "string" },
        "student_id": { "type": "string" },
        "teacher_id": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent"] }
      },
      "required": ["timestamp", "tenant_id", "student_id", "teacher_id", "subject", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A bank log for payments (bKash/Nagad).",
      "type": "object",
      "properties": {
        "trx_id": { "type": "string" },
        "amount": { "type": "number" },
        "sender_number": { "type": "string" },
        "status": { "type": "string", "enum": ["unused", "used"] },
        "claimed_by_tenant": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["trx_id", "amount", "status"]
    },
    "Reward": {
      "title": "Reward",
      "description": "Tracking daily share rewards.",
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "date": { "type": "string" },
        "claimed": { "type": "boolean" }
      },
      "required": ["tenant_id", "date", "claimed"]
    }
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Tenant settings and credits."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "/tenants/{tenantId}/students/{studentId}": {
      "schema": "Student",
      "description": "Students within a tenant."
    },
    "/tenants/{tenantId}/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records for a tenant."
    },
    "/transactions/{trxId}": {
      "schema": "Transaction",
      "description": "Global bank logs for payment verification."
    },
    "/tenants/{tenantId}/rewards/{rewardId}": {
      "schema": "Reward",
      "description": "Daily reward tracking per tenant."
    }
  }
}
