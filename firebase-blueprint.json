{
  "entities": {
    "Institution": {
      "title": "Institution",
      "description": "Represents a school, college, or coaching center (tenant).",
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string", "description": "Unique identifier for the institution." },
        "name": { "type": "string", "description": "Name of the institution." },
        "eiin": { "type": "string", "description": "EIIN or Registration Number." },
        "institutionType": { "type": "string", "enum": ["School", "College", "Madrasa", "Coaching Center"] },
        "credits_left": { "type": "number", "description": "Remaining credits for attendance." },
        "status": { "type": "string", "enum": ["active", "suspended", "deactivated"] },
        "admin_name": { "type": "string" },
        "admin_mobile": { "type": "string" },
        "owner_email": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["tenant_id", "name", "eiin", "credits_left"]
    },
    "User": {
      "title": "User",
      "description": "Represents any user in the system (SuperAdmin, Admin, Teacher, Student).",
      "type": "object",
      "properties": {
        "user_id": { "type": "string", "description": "Firebase Auth UID." },
        "tenant_id": { "type": "string", "description": "The institution this user belongs to." },
        "role": { "type": "string", "enum": ["SuperAdmin", "InstitutionAdmin", "Teacher", "Student"] },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "student_id": { "type": "string", "description": "Specific to students." },
        "teacher_id": { "type": "string", "description": "Specific to teachers." },
        "class": { "type": "string" },
        "section": { "type": "string" }
      },
      "required": ["user_id", "tenant_id", "role", "name", "status"]
    },
    "SessionCode": {
      "title": "SessionCode",
      "description": "Temporary codes for attendance sessions or verification.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "tenant_id": { "type": "string" },
        "teacher_id": { "type": "string" },
        "subject": { "type": "string" },
        "expires_at": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "tenant_id", "expires_at"]
    }
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "Institution",
      "description": "Collection of institutions."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of all users."
    },
    "/session_codes/{codeId}": {
      "schema": "SessionCode",
      "description": "Collection of active session codes."
    }
  }
}
