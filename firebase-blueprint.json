{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Information about an educational institution",
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "name": { "type": "string" },
        "nameBN": { "type": "string" },
        "eiin": { "type": "string" },
        "googleSheetId": { "type": "string" },
        "owner_email": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended", "pending"] },
        "credits_left": { "type": "number" },
        "academicLevels": { "type": "array" }
      },
      "required": ["tenant_id", "name", "owner_email"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "institute_admin", "teacher", "student"] },
        "tenant_id": { "type": "string" },
        "status": { "type": "string", "enum": ["approved", "pending", "blocked"] },
        "fcmToken": { "type": "string" }
      },
      "required": ["user_id", "email", "role"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification sent to a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "link": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "title", "body", "createdAt"]
    },
    "TeacherClass": {
      "title": "TeacherClass",
      "description": "Classes assigned to or created by a teacher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacher_id": { "type": "string" },
        "name": { "type": "string" },
        "nameBN": { "type": "string" },
        "section": { "type": "string" },
        "studentCount": { "type": "number" },
        "created_by": { "type": "string" },
        "type": { "type": "string", "enum": ["assigned", "self-created"] }
      },
      "required": ["teacher_id", "name"]
    },
    "AttendanceLog": {
      "title": "AttendanceLog",
      "description": "Historical attendance records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "classId": { "type": "string" },
        "teacherId": { "type": "string" },
        "subject": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "method": { "type": "string" },
        "stats": { 
          "type": "object",
          "properties": {
            "present": { "type": "number" },
            "absent": { "type": "number" },
            "total": { "type": "number" }
          }
        },
        "attendance": { "type": "object", "description": "studentId -> status mapping" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["classId", "teacherId", "date", "attendance"]
    },
    "AttendanceSession": {
      "title": "AttendanceSession",
      "description": "Active session for students to check-in",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "teacherId": { "type": "string" },
        "method": { "type": "string" },
        "code": { "type": "string" },
        "active": { "type": "boolean" },
        "subject": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    },
    "AttendanceEntry": {
      "title": "AttendanceEntry",
      "description": "Individual student check-in record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "name": { "type": "string" },
        "classId": { "type": "string" },
        "method": { "type": "string" },
        "code": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Collection of all tenants (institutes)"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Global collection of all users"
    },
    "/tenants/{tenantId}/teachers/{teacherId}": {
      "schema": "User",
      "description": "Subcollection for teacher quick lookup"
    },
    "/tenants/{tenantId}/students/{studentId}": {
      "schema": "User",
      "description": "Subcollection for student quick lookup"
    },
    "/tenants/{tenantId}/teacher_classes/{classId}": {
      "schema": "TeacherClass",
      "description": "Classes managed by teachers within a tenant"
    },
    "/tenants/{tenantId}/attendance_logs/{logId}": {
      "schema": "AttendanceLog",
      "description": "Historical attendance records"
    },
    "/tenants/{tenantId}/attendance_sessions/{sessionId}": {
      "schema": "AttendanceSession",
      "description": "Active attendance sessions"
    },
    "/tenants/{tenantId}/attendance_entries/{entryId}": {
      "schema": "AttendanceEntry",
      "description": "Student check-in entries"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
